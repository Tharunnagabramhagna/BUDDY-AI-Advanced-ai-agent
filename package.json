{
  "name": "buddy-ai-temp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev-full": "start cmd /c npm run dev & npm start",
    "cleanup": "taskkill /F /IM electron.exe /T 2>nul & taskkill /F /IM python.exe /T 2>nul & exit 0",
    "prestart": "npm run cleanup",
    "start": "start cmd /c npm run dev && timeout /t 3 /nobreak && npm run electron",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "set \"ELECTRON_RUN_AS_NODE=\" && electron electron/main.cjs"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "lucide-react": "^0.576.0",
    "puppeteer-core": "^24.40.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "electron": "^34.5.8",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1"
  }
}
